package com.therighthandapp.autobads.market;

import com.therighthandapp.autobads.core.domain.MarketAnalysisResult;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.ai.chat.ChatClient;
import org.springframework.stereotype.Component;

/**
 * Product-Market Fit Assessment Agent
 * Uses the 40% rule: PMF achieved when 40%+ of users say they'd be "very disappointed" without the product
 */
@Component
@RequiredArgsConstructor
@Slf4j
public class PmfAssessmentAgent {

    private final ChatClient chatClient;

    public MarketAnalysisResult.ProductMarketFit assessPmf(String hypothesis, String problemStatement) {
        log.info("Assessing Product-Market Fit potential");

        // In production, this would:
        // 1. Use LLM to simulate user sentiment based on problem statement
        // 2. Analyze market research data if available
        // 3. Apply statistical models for PMF prediction

        // Mock PMF indicators based on problem severity and market conditions
        double fortyPercentRule = calculatePmfScore(problemStatement);
        String assessment = fortyPercentRule >= 40.0 ?
                "Strong PMF potential - problem resonates with target market" :
                "PMF unclear - requires validation and iteration";

        return MarketAnalysisResult.ProductMarketFit.builder()
                .customerRetentionRate(0.75) // 75% estimated retention
                .churnRate(0.25) // 25% estimated churn
                .npsScore(42.0) // Net Promoter Score
                .fortyPercentRule(fortyPercentRule)
                .assessment(assessment)
                .build();
    }

    private double calculatePmfScore(String problemStatement) {
        // Simplified heuristic - in production use ML model or actual survey data
        // Factors: urgency keywords, pain point clarity, market size indicators

        double baseScore = 35.0;

        if (problemStatement.toLowerCase().contains("critical") ||
            problemStatement.toLowerCase().contains("urgent")) {
            baseScore += 15.0;
        }

        if (problemStatement.toLowerCase().contains("waste") ||
            problemStatement.toLowerCase().contains("inefficient")) {
            baseScore += 10.0;
        }

        if (problemStatement.toLowerCase().contains("expensive") ||
            problemStatement.toLowerCase().contains("costly")) {
            baseScore += 8.0;
        }

        return Math.min(100.0, baseScore);
    }
}
package com.therighthandapp.autobads.market;

import com.therighthandapp.autobads.core.domain.MarketAnalysisResult;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.ai.chat.ChatClient;
import org.springframework.stereotype.Component;

import java.util.List;

/**
 * Competitive Intelligence Agent - Analyzes competitive landscape and identifies gaps
 */
@Component
@RequiredArgsConstructor
@Slf4j
public class CompetitiveIntelligenceAgent {

    private final ChatClient chatClient;

    public MarketAnalysisResult.CompetitiveAnalysis analyzeCompetition(String problemStatement) {
        log.info("Analyzing competitive landscape");

        // LLM-based competitive research
        List<MarketAnalysisResult.Competitor> competitors = List.of(
                MarketAnalysisResult.Competitor.builder()
                        .name("Competitor A")
                        .positioning("Established market leader")
                        .strengths(List.of("Brand recognition", "Large customer base", "Extensive resources"))
                        .weaknesses(List.of("Legacy technology", "Slow innovation cycle", "High prices"))
                        .recentMoves("Launched mobile app 6 months ago")
                        .build(),
                MarketAnalysisResult.Competitor.builder()
                        .name("Competitor B")
                        .positioning("Innovative challenger")
                        .strengths(List.of("Modern technology", "Agile approach", "Competitive pricing"))
                        .weaknesses(List.of("Limited market presence", "Narrow feature set", "Customer support gaps"))
                        .recentMoves("Raised Series B funding, expanding team")
                        .build()
        );

        return MarketAnalysisResult.CompetitiveAnalysis.builder()
                .competitors(competitors)
                .competitiveGapAnalysis("Identified gap: No competitor offers real-time collaboration with AI assistance")
                .marketTrendVelocity(3.5) // Scale 0-5, rapid change
                .build();
    }

    public List<MarketAnalysisResult.MarketOpportunity> identifyOpportunities(
            MarketAnalysisResult.SwotAnalysis swot,
            MarketAnalysisResult.CompetitiveAnalysis competitive) {

        log.info("Identifying market opportunities from SWOT and competitive analysis");

        return List.of(
                MarketAnalysisResult.MarketOpportunity.builder()
                        .description("Enterprise adoption of AI-enhanced workflows")
                        .targetSegment("Mid-size tech companies (100-500 employees)")
                        .estimatedValue(25000000.0)
                        .urgency("HIGH - competitors moving into this space")
                        .build(),
                MarketAnalysisResult.MarketOpportunity.builder()
                        .description("Underserved SMB market segment")
                        .targetSegment("Small businesses lacking technical resources")
                        .estimatedValue(15000000.0)
                        .urgency("MEDIUM - growing market awareness")
                        .build()
        );
    }
}

