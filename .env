# Auto-BADS Environment Variables
# Local Docker deployment configuration

# OpenAI API Configuration
OPENAI_API_KEY=sk-test-key-for-local-development

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=autobads
DB_USERNAME=autobads
DB_PASSWORD=autobads_password_local

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Application Configuration
AUTO_BADS_PMF_THRESHOLD=40.0

# Monitoring
GRAFANA_ADMIN_PASSWORD=admin

# Docker Configuration
COMPOSE_PROJECT_NAME=autobads

